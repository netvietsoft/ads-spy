generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Search {
  id              Int      @id @default(autoincrement())
  domain          String
  createdAt       DateTime @default(now())
  advertiserCount Int      @default(0)
  creativeCount   Int      @default(0)
  totalMin        Int?
  totalMax        Int?
  advertisers     Advertiser[]
  creatives       Creative[]
}

model Advertiser {
  id        Int     @id @default(autoincrement())
  arId      String // AR...
  name      String
  domain    String?
  adCount   Int     @default(0)
  search    Search  @relation(fields: [searchId], references: [id], onDelete: Cascade)
  searchId  Int
}

model Creative {
  id           Int      @id @default(autoincrement())
  crId         String // CR...
  advertiserId String // AR...
  advertiserName String @default("")
  domain       String?
  assetType    String   @default("unknown")
  assetUrl     String?
  firstShown   Int?
  lastShown    Int?
  search       Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  searchId     Int
}

// ---- Cấu hình FB (lưu cookie phiên để sống qua restart) ----
model FbSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// ---- Đối thủ theo dõi (favorites) — cho cả Google lẫn Facebook ----
model Favorite {
  id        Int      @id @default(autoincrement())
  source    String // 'google' | 'facebook'
  query     String // domain/keyword (google) | keyword/link/page_id (fb)
  country   String? // chỉ dùng cho facebook
  label     String?
  createdAt DateTime @default(now())
}

// ---- Facebook Ad Library ----
model FbSearch {
  id        Int      @id @default(autoincrement())
  query     String
  country   String
  createdAt DateTime @default(now())
  adCount   Int      @default(0)
  ads       FbAd[]
}

model FbAd {
  id            Int      @id @default(autoincrement())
  adArchiveId   String
  pageId        String?
  pageName      String   @default("")
  isActive      Boolean?
  platforms     String?  // JSON array
  bodyText      String?
  linkUrl       String?
  ctaText       String?
  images        String?  // JSON array
  videos        String?  // JSON array
  startedRunning String?
  snapshotUrl   String?
  fbSearch      FbSearch @relation(fields: [fbSearchId], references: [id], onDelete: Cascade)
  fbSearchId    Int
}
