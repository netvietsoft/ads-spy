# ===== API (apps/api) =====
# Cổng API NestJS
PORT=3100

# ===== WEB (apps/web) =====
# URL công khai của API mà TRÌNH DUYỆT sẽ gọi tới.
# Web gọi thẳng API (không qua proxy) vì FB scraping chạy 30-60s.
# LƯU Ý: biến này được nhúng lúc `next build` → phải đặt TRƯỚC khi build web.
#  - Cùng VPS, mở cổng 3100:      http://IP_VPS:3100
#  - Có domain + nginx cho API:   https://api.ads-spy.your-domain.com
NEXT_PUBLIC_API_ORIGIN=http://localhost:3100

# (tuỳ chọn) Cổng web
# PORT=3101

# ===== ShopHunter (apps/api) =====
# MySQL riêng cho dữ liệu ShopHunter (Laragon local: root không mật khẩu).
SH_MYSQL_URL=mysql://root@127.0.0.1:3306/shophunter
# TTL cache explore (giờ). ShopHunter cập nhật ~hàng giờ; 6h để tiết kiệm call.
SH_CACHE_TTL_HOURS=6

# ShopHunter harvest (nền, deep-scroll theo revenue)
# Bật cron nightly harvest (mặc định tắt — chạy thủ công qua sh/harvest/run).
SH_HARVEST_ENABLED=false
# Lịch cron (mặc định 3h sáng).
SH_HARVEST_CRON=0 3 * * *
# Số shop tối đa mỗi lần chạy.
SH_HARVEST_DAILY=1000
# Delay (ms) giữa các batch để tránh bị chặn.
SH_HARVEST_DELAY_MS=500
# Số shopDetail gọi đồng thời.
SH_HARVEST_CONCURRENCY=2
# Sort key dùng để deep-scroll theo revenue cao→thấp.
SH_HARVEST_SORT=month_current_period_revenue
