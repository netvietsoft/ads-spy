# ===== API (apps/api) =====
# Cổng API NestJS
PORT=3100

# ===== WEB (apps/web) =====
# URL công khai của API mà TRÌNH DUYỆT sẽ gọi tới.
# Web gọi thẳng API (không qua proxy) vì FB scraping chạy 30-60s.
# LƯU Ý: biến này được nhúng lúc `next build` → phải đặt TRƯỚC khi build web.
#  - Cùng VPS, mở cổng 3100:      http://IP_VPS:3100
#  - Có domain + nginx cho API:   https://api.ads-spy.your-domain.com
NEXT_PUBLIC_API_ORIGIN=http://localhost:3100

# (tuỳ chọn) Cổng web
# PORT=3101

# ===== ShopHunter (apps/api) =====
# MySQL riêng cho dữ liệu ShopHunter (Laragon local: root không mật khẩu).
SH_MYSQL_URL=mysql://root@127.0.0.1:3306/shophunter
# TTL cache explore (giờ). ShopHunter cập nhật ~hàng giờ; 6h để tiết kiệm call.
SH_CACHE_TTL_HOURS=6

# ShopHunter harvest (nền, deep-scroll theo revenue)
# Bật cron nightly harvest (mặc định tắt — chạy thủ công qua sh/harvest/run).
SH_HARVEST_ENABLED=false
# Lịch cron (mỗi 30 phút — cron "người thường" uống ngụm nhỏ, không burst).
SH_HARVEST_CRON=*/30 * * * *
# Trần shop/ngày (đếm bền qua sh_harvest_daily).
SH_HARVEST_DAILY=500
# Sort key dùng để deep-scroll theo revenue cao→thấp.
SH_HARVEST_SORT=month_current_period_revenue

# Harvest phase 2 (slice category+country vượt trần 10k)
SH_HARVEST_MODE=slices        # slices (category+country) | flat (cuộn 1 chiều)
SH_HARVEST_FRESH_DAYS=7       # dedup: bỏ qua shop đã harvest trong X ngày

# Gentle cron (người thường): rải nhỏ, jitter, chỉ giờ thức
SH_HARVEST_ACTIVE_START=8      # giờ bắt đầu chạy
SH_HARVEST_ACTIVE_END=23       # giờ dừng (exclusive)
SH_HARVEST_SIP_MIN=10          # ngụm nhỏ nhất/lần fire
SH_HARVEST_SIP_MAX=25          # ngụm lớn nhất/lần fire
SH_HARVEST_DELAY_MIN_MS=1500   # delay random giữa shop (min)
SH_HARVEST_DELAY_MAX_MS=3000   # delay random giữa shop (max)
SH_HARVEST_SKIP_PCT=30         # % lần fire bỏ ngẫu nhiên (bất quy luật)
SH_HARVEST_JITTER_MS=480000    # jitter chờ đầu mỗi fire (0..8 phút)
SH_HARVEST_CONCURRENCY=1       # số shopDetail đồng thời (1 = giống người)
